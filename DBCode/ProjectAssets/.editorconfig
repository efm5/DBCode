root = true

# ---------------------------------------------
# DBCode Coding Standards (Solution-Level)
# ---------------------------------------------

# Prefer nullable reference types in generated code
dotnet_style_prefer_nullable_reference_types = true:suggestion

# Require explicit accessibility modifiers (public/private/etc.)
dotnet_style_require_accessibility_modifiers = always

# Prefer null-propagation (x?.y)
dotnet_style_prefer_null_propagation = true

# Prefer modern null checks (x is null)
dotnet_style_prefer_is_null_check_over_reference_equality_method = true

# Do NOT suggest converting private fields to auto-properties
dotnet_diagnostic.IDE0032.severity = none


# ---------------------------------------------
# Naming Rules — Parameters
# ---------------------------------------------

dotnet_naming_rule.parameters_must_be_prefixed_with_p.severity = warning
dotnet_naming_rule.parameters_must_be_prefixed_with_p.symbols = parameters
dotnet_naming_rule.parameters_must_be_prefixed_with_p.style = prefix_p

dotnet_naming_symbols.parameters.applicable_kinds = parameter
dotnet_naming_symbols.parameters.applicable_accessibilities = *
dotnet_naming_symbols.parameters.required_modifiers = *

dotnet_naming_style.prefix_p.required_prefix = p
dotnet_naming_style.prefix_p.capitalization = camel_case


# ---------------------------------------------
# Naming Rules — Locals
# ---------------------------------------------

dotnet_naming_rule.locals_must_be_camel_case.severity = suggestion
dotnet_naming_rule.locals_must_be_camel_case.symbols = locals
dotnet_naming_rule.locals_must_be_camel_case.style = camel_case_style

dotnet_naming_symbols.locals.applicable_kinds = local
dotnet_naming_symbols.locals.applicable_accessibilities = *
dotnet_naming_symbols.locals.required_modifiers = *

dotnet_naming_style.camel_case_style.capitalization = camel_case


# ---------------------------------------------
# Naming Rules — Types & Methods (from root config)
# ---------------------------------------------

dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case

dotnet_naming_rule.method_should_be_pascal_case.symbols = method
dotnet_naming_rule.method_should_be_pascal_case.style = pascal_case

dotnet_naming_rule.parameter_should_be_parameter_p_prefix.symbols = parameter
dotnet_naming_rule.parameter_should_be_parameter_p_prefix.style = parameter_p_prefix

dotnet_naming_rule.parameter_should_be_parameter_op_prefix.symbols = outparameter
dotnet_naming_rule.parameter_should_be_parameter_op_prefix.style = parameter_op_prefix

dotnet_naming_style.pascal_case.capitalization = pascal_case
dotnet_naming_style.parameter_p_prefix.required_prefix = p
dotnet_naming_style.parameter_p_prefix.capitalization = pascal_case
dotnet_naming_style.parameter_op_prefix.required_prefix = po
dotnet_naming_style.parameter_op_prefix.capitalization = pascal_case

dotnet_naming_symbols.method.applicable_kinds = method
dotnet_naming_symbols.types.applicable_kinds = class, struct, interface, enum
dotnet_naming_symbols.parameter.applicable_kinds = parameter
dotnet_naming_symbols.outparameter.applicable_kinds = parameter
dotnet_naming_symbols.outparameter.required_modifiers = out


# ---------------------------------------------
# C# Formatting Rules (from root config)
# ---------------------------------------------

[*.cs]

# Indentation and spacing
indent_size = 3
indent_style = space
tab_width = 3

# Using directives
csharp_using_directive_placement = outside_namespace

# Namespaces
csharp_style_namespace_declarations = block_scoped

# Braces and formatting
csharp_new_line_before_open_brace = none
csharp_preserve_single_line_blocks = true
csharp_preserve_single_line_statements = false

# var usage
csharp_style_var_elsewhere = false
csharp_style_var_for_built_in_types = false
csharp_style_var_when_type_is_apparent = false

# Expression-bodied members
csharp_style_expression_bodied_methods = false
csharp_style_expression_bodied_accessors = true
csharp_style_expression_bodied_constructors = true
csharp_style_expression_bodied_indexers = true
csharp_style_expression_bodied_lambdas = true
csharp_style_expression_bodied_local_functions = true
csharp_style_expression_bodied_operators = false
csharp_style_expression_bodied_properties = true

# Language style
csharp_style_prefer_utf8_string_literals = true
csharp_style_prefer_simplified_boolean_expressions = true
csharp_style_prefer_simplified_interpolation = true
csharp_style_prefer_method_group_conversion = true
csharp_style_prefer_primary_constructors = true
csharp_style_prefer_simple_property_accessors = true
csharp_style_prefer_null_check_over_type_check = true
csharp_style_prefer_local_over_anonymous_function = true
csharp_style_prefer_implicitly_typed_lambda_expression = true
csharp_style_prefer_readonly_struct = true
csharp_style_prefer_readonly_struct_member = true

# Object and collection initialization
dotnet_style_object_initializer = true
dotnet_style_collection_initializer = true
dotnet_style_prefer_collection_expression = when_types_loosely_match

# Compound assignments
dotnet_style_prefer_compound_assignment = true


# ---------------------------------------------
# Global Formatting Rules (apply to all files)
# ---------------------------------------------
[*]
end_of_line = crlf
insert_final_newline = true
